{
  "expo": {
    "name": "PrimaPrompter",
    "slug": "primaprompter",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.primakor.primaprompter"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.primakor.primaprompter"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "PrimaPrompter uses the camera to record your videos — everything stays on your device.",
          "enableMicrophonePermission": true,
          "microphonePermissionText": "PrimaPrompter uses the microphone to record audio with your videos — everything stays on your device."
        }
      ],
      "expo-video",
      [
        "expo-media-library",
        {
          "photosPermission": false,
          "savePhotosPermission": "PrimaPrompter saves a recording to your Photos only when you tap Save. It never reads your photo library.",
          "isAccessMediaLocationEnabled": false,
          "preventAutomaticLimitedAccessAlert": true
        }
      ]
    ]
  }
}
